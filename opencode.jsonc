{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "figma-developer-mcp", "--stdio", "--env", ".env.figma"],
      "enabled": true
    },
    "pixso": {
      "type": "remote",
      "url": "http://127.0.0.1:3667/mcp",
      "enabled": true
    }
  }
}
